# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# A long random string used to sign the session cookie.
SESSION_SECRET=change-me-to-a-long-random-string

# ─── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite database file (default: contacts.db in the project root).
# DB_PATH=/absolute/path/to/contacts.db

# ─── LinkedIn OAuth 2.0 ───────────────────────────────────────────────────────
# Register your app at https://www.linkedin.com/developers/apps
# Required scopes: openid, profile, email
# Authorised redirect URL: http://localhost:3000/auth/linkedin/callback
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=http://localhost:3000/auth/linkedin/callback

# ─── Facebook OAuth 2.0 ───────────────────────────────────────────────────────
# Register your app at https://developers.facebook.com/apps/
# Required permissions: email, public_profile
# Valid OAuth redirect URI: http://localhost:3000/auth/facebook/callback
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/auth/facebook/callback

# ─── Instagram Basic Display API ──────────────────────────────────────────────
# Register your app at https://developers.facebook.com/apps/ → Instagram Basic Display
# Required scopes: user_profile, user_media
# Valid OAuth redirect URI: http://localhost:3000/auth/instagram/callback
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret
INSTAGRAM_CALLBACK_URL=http://localhost:3000/auth/instagram/callback
